{
  "SPN Domain Agent": {
    "bearerAuth": {
      "login_url": "https://<YOUR_HOST>:<YOUR_PORT>/rest/plat/smapp/v1/oauth/token",
      "method": "PUT",
      "request_fields": {
        "grantType": "password",
        "userName": "<YOUR_USERNAME>",
        "value": "<YOUR_PASSWORD>",
        "ipaddr": "*"
      },
      "token_field": "accessSession"
    }
  },
  "Workbench Platform Agent": {
    "bearerAuth": {
      "login_url": "http://<YOUR_HOST>:<YOUR_PORT>/bgw/cswg-service/oauth/token",
      "method": "POST",
      "content_type": "application/x-www-form-urlencoded",
      "request_fields": {
        "grant_type": "password",
        "username": "<YOUR_USERNAME>",
        "password": "<YOUR_PASSWORD_ENCRYPTED>",
        "client_id": "<YOUR_CLIENT_ID>",
        "mode": "plain"
      },
      "token_field": "data.access_token",
      "auth_header": "fmind-auth",
      "accept_header": "*/*"
    }
  }
}
